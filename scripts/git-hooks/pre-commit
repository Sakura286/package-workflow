#!/usr/bin/env bash
# Cross-agent git pre-commit guard for the openRuyi spec-repo clones. It first
# enforces the required commit identity, then runs the repository's pre-commit
# checks when a .pre-commit-config.yaml is present. Fires for ANY tool (Claude
# Code, mimo code, opencode, codebuddy, a human, …) that runs `git commit`,
# because it is enforced by git itself, not by an agent.
#
# Installed by pointing each spec repo's core.hooksPath at scripts/git-hooks/
# (see scripts/install-git-hooks.sh). Bypassable with `git commit --no-verify`;
# the unbypassable backstop would be a server-side check (not configured).
set -u

EXPECT="chenxuan@iscas.ac.cn"

# Safety: only enforce inside the spec-repo clones, so an accidental
# core.hooksPath on another repo (e.g. package-workflow, which commits as
# Sakura286) is a no-op.
top=$(git rev-parse --show-toplevel 2>/dev/null) || exit 0
case "$(basename "$top")" in
    rocm-specs|openRuyi) ;;
    *) exit 0 ;;
esac

# `git var` reflects the identity git will actually record (config + env),
# so this also catches GIT_AUTHOR_EMAIL / GIT_COMMITTER_EMAIL overrides.
email_of() { git var "$1" 2>/dev/null | sed -n 's/.*<\(.*\)>.*/\1/p'; }
author=$(email_of GIT_AUTHOR_IDENT)
committer=$(email_of GIT_COMMITTER_IDENT)

bad=""
[[ $author    != "$EXPECT" ]] && bad+="author=<${author:-unset}> "
[[ $committer != "$EXPECT" ]] && bad+="committer=<${committer:-unset}> "

if [[ -n $bad ]]; then
    {
        echo "pre-commit: refusing commit in $(basename "$top")."
        echo "  This spec repo must commit as CHEN Xuan <$EXPECT>, but got: $bad"
        echo "  Fix identity, then retry:"
        echo "    git -C \"$top\" config user.name  \"CHEN Xuan\""
        echo "    git -C \"$top\" config user.email $EXPECT"
    } >&2
    exit 1
fi

config="$top/.pre-commit-config.yaml"
[[ -f $config ]] || exit 0

if ! command -v pre-commit >/dev/null 2>&1; then
    {
        echo "pre-commit: command not found; refusing commit in $(basename "$top")."
        echo "  Install pre-commit, then retry the commit."
    } >&2
    exit 1
fi

exec pre-commit run --config "$config" --hook-stage pre-commit
