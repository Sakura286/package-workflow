#!/usr/bin/env bash
# =============================================================================
# obs-fetch-log - Fetch build log from OBS
# =============================================================================
# Usage:
#   ./obs-fetch-log <project> <package> <repo> <arch> [output_file]
#
# If output_file is not specified, saves to log/<package>-<timestamp>.log
# =============================================================================

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
WORKSPACE_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
LOG_DIR="$WORKSPACE_ROOT/log"

PROJECT="${1:?Usage: $0 <project> <package> <repo> <arch> [output_file]}"
PACKAGE="${2:?}"
REPO="${3:?}"
ARCH="${4:?}"
OUTPUT="${5:-$LOG_DIR/${PACKAGE}-${REPO}-$(date '+%Y%m%d-%H%M%S').log}"

mkdir -p "$(dirname "$OUTPUT")"

# Fetch log via osc remotebuildlog (primary) or API (fallback)
osc -A https://pickaxe.oerv.ac.cn rbl "$PROJECT" "$PACKAGE" "$REPO" "$ARCH" > "$OUTPUT" 2>/dev/null || {
    osc -A https://pickaxe.oerv.ac.cn api "/build/$PROJECT/$REPO/$ARCH/$PACKAGE/_log" > "$OUTPUT" 2>/dev/null || {
        echo "Failed to fetch log"
        exit 1
    }
}

echo "$OUTPUT"
